# .env.example - Copy to .env and fill values
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/recruitment_db
# Example Atlas: mongodb+srv://user:pass@cluster.mongodb.net/recruitment_db?retryWrites=true&w=majority

# JWT Secret (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long-for-security

# Admin Account (auto-seeded on first dev run)
ADMIN_EMAIL=admin@smartrecruit.com
ADMIN_PASSWORD=Admin@Pass123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=System

# Cloudinary (sign up at cloudinary.com)
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI API
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Email (SMTP - Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
# Note: For Gmail, enable 2FA & App Passwords

# ============================================
# Run `npm run dev` after setup!

